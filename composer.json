{
  "name": "manzadey/laravel-orchid-helpers",
  "description": "Laravel Orchid helpers package providing reusable components for Orchid Platform",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andrey Manzadey",
      "email": "andrey.manzadey@gmail.com",
      "homepage": "https://manzaday.ru",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.3",
    "ext-json": "*",
    "orchid/platform": "^14.53"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "orchestra/testbench": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Manzadey\\LaravelOrchidHelpers\\": "src/"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "Manzadey\\LaravelOrchidHelpers\\Providers\\FoundationServiceProvider",
        "Manzadey\\LaravelOrchidHelpers\\Providers\\MacrosServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "keywords": [
    "laravel",
    "orchid",
    "helpers",
    "admin",
    "panel",
    "cms"
  ]
}