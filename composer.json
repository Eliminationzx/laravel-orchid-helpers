{
  "name": "eliminationzx/laravel-orchid-helpers",
  "description": "Laravel Orchid helpers package providing reusable components for Orchid Platform",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Eliminationzx",
      "email": "eliminationzx@proton.me",
      "homepage": "https://github.com/Eliminationzx",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.3",
    "ext-json": "*",
    "orchid/platform": "^14.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.0",
    "orchestra/testbench": "^11.0",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "OrchidHelpers\\": "src/"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "OrchidHelpers\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "OrchidHelpers\\Providers\\FoundationServiceProvider",
        "OrchidHelpers\\Providers\\MacrosServiceProvider",
        "OrchidHelpers\\Providers\\ComponentServiceProvider",
        "OrchidHelpers\\Providers\\ViewServiceProvider",
        "OrchidHelpers\\Providers\\RouteServiceProvider",
        "OrchidHelpers\\Providers\\EventServiceProvider",
        "OrchidHelpers\\Providers\\CommandServiceProvider",
        "OrchidHelpers\\Providers\\MigrationServiceProvider",
        "OrchidHelpers\\Providers\\ValidationServiceProvider",
        "OrchidHelpers\\Providers\\HelperServiceProvider",
        "OrchidHelpers\\Providers\\ConfigServiceProvider",
        "OrchidHelpers\\Providers\\MiddlewareServiceProvider",
        "OrchidHelpers\\Providers\\PolicyServiceProvider",
        "OrchidHelpers\\Providers\\RepositoryServiceProvider",
        "OrchidHelpers\\Providers\\ServiceServiceProvider",
        "OrchidHelpers\\Providers\\FacadeServiceProvider",
        "OrchidHelpers\\Providers\\CacheServiceProvider",
        "OrchidHelpers\\Providers\\QueueServiceProvider",
        "OrchidHelpers\\Providers\\MailServiceProvider",
        "OrchidHelpers\\Providers\\NotificationServiceProvider",
        "OrchidHelpers\\Providers\\BroadcastServiceProvider",
        "OrchidHelpers\\Providers\\AuthServiceProvider",
        "OrchidHelpers\\Providers\\DatabaseServiceProvider",
        "OrchidHelpers\\Providers\\FilesystemServiceProvider",
        "OrchidHelpers\\Providers\\SessionServiceProvider",
        "OrchidHelpers\\Providers\\TranslationServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "test:unit": "vendor/bin/phpunit --testsuite=Unit",
    "test:feature": "vendor/bin/phpunit --testsuite=Feature",
    "test:coverage": "vendor/bin/phpunit --coverage-html coverage"
  },
  "keywords": [
    "laravel",
    "orchid",
    "helpers",
    "admin",
    "panel",
    "cms"
  ]
}